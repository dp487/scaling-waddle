# Server configuration
SERVER_HOST=localhost
SERVER_PORT=9010

# Database configuration
DB_USER=root
DB_PASS=password
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=bookstore

# Database DSN for MySQL
DB_DSN="${DB_USER}:${DB_PASS}@tcp(${DB_HOST}:${DB_PORT})/${DB_NAME}?charset=utf8mb4&parseTime=True&loc=Local"
